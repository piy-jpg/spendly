{
  "version": 2,
  "name": "spendly",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {},
  "installCommand": "npm install",
  "buildCommand": "echo 'No build required for Node.js'",
  "outputDirectory": ".",
  "framework": null,
  "regions": ["iad1"],
  "functionsDirectory": "api",
  "publicDirectory": "public",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/server.js"
    }
  ]
}
