<%- include("partials/crm-shell-start", { title, currentUser, flashes, crmActiveNav: "recommendations", crmTitle: "Recommendations", crmSearchAction: "/dashboard" }) %>

<section class="dashboard-page">
  <div class="dashboard-shell dashboard-stack">
    <div class="dashboard-header">
      <div>
        <p class="dashboard-eyebrow">Smart</p>
        <h1 class="dashboard-title">Recommendations</h1>
        <p class="dashboard-subtitle">Action-oriented guidance built from your budget pace, trends, and current alerts.</p>
      </div>
      <a href="/insights" class="btn-primary">Open insights</a>
    </div>

    <section class="dashboard-card">
      <div class="card-head">
        <h2>Recommended actions</h2>
        <span class="card-note">Prioritized guidance</span>
      </div>
      <div class="insight-list">
        <% recommendations.forEach((item) => { %>
          <div class="insight-item insight-item--smart">
            <span class="insight-label"><%= item.priority %></span>
            <strong><%= item.title %></strong>
            <p><%= item.body %></p>
          </div>
        <% }) %>
      </div>
    </section>
  </div>
</section>

<%- include("partials/crm-shell-end") %>
