<%- include("partials/header", { title, currentUser, flashes, extraCss: null }) %>

<section class="auth-workspace">
  <aside class="auth-panel">
    <div>
      <div class="auth-brand">
        <span class="auth-brand-icon">◈</span>
        <span>SPENDLY</span>
      </div>
      <h1>Sign in to your workspace.</h1>
      <p>Jump back into the CRM-style dashboard, review budgets, and manage spending activity from one structured workspace.</p>
    </div>

    <div class="auth-points">
      <div class="auth-point">Dashboard-led navigation across Finance, Team, Smart, Tools, and System.</div>
      <div class="auth-point">Persistent session support so reloads and restarts don’t drop your workspace context.</div>
      <div class="auth-point">Quick actions for adding expenses, exporting data, and reviewing alerts.</div>
    </div>
  </aside>

  <div class="auth-main">
    <div class="auth-card">
      <div class="auth-form-head">
        <h2>Welcome back</h2>
        <p>Sign in to continue to your Spendly dashboard.</p>
      </div>

      <form method="POST" action="/login">
        <div class="form-group">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" class="form-input" placeholder="you@example.com" required autofocus>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" class="form-input" placeholder="Your password" required>
        </div>
        <button type="submit" class="btn-submit">Sign in</button>
      </form>

      <p class="auth-switch">
        Don't have an account?
        <a href="/register">Create one free</a>
      </p>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
