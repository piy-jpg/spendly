<%- include("partials/header", { title, currentUser, flashes, extraCss: null }) %>

<section class="auth-workspace">
  <aside class="auth-panel">
    <div>
      <div class="auth-brand">
        <span class="auth-brand-icon">◈</span>
        <span>SPENDLY</span>
      </div>
      <h1>Create your finance workspace.</h1>
      <p>Set up your account and start using the dashboard-style experience for expenses, analytics, goals, insights, and team collaboration.</p>
    </div>

    <div class="auth-points">
      <div class="auth-point">Track expenses, transactions, budgets, analytics, and savings goals.</div>
      <div class="auth-point">Use smart pages like Insights, Recommendations, and Forecast.</div>
      <div class="auth-point">Organize work across people, groups, reports, notifications, and help.</div>
    </div>
  </aside>

  <div class="auth-main">
    <div class="auth-card">
      <div class="auth-form-head">
        <h2>Create account</h2>
        <p>Start tracking your money inside the full Spendly workspace.</p>
      </div>

      <form method="POST" action="/register">
        <div class="form-group">
          <label for="name">Full name</label>
          <input type="text" id="name" name="name" class="form-input" placeholder="Your name" required autofocus>
        </div>
        <div class="form-group">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" class="form-input" placeholder="you@example.com" required>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" class="form-input" placeholder="Min. 8 characters" required>
        </div>
        <div class="form-group">
          <label for="confirm_password">Confirm password</label>
          <input type="password" id="confirm_password" name="confirm_password" class="form-input" placeholder="Repeat your password" required>
        </div>
        <button type="submit" class="btn-submit">Create account</button>
      </form>

      <p class="auth-switch">
        Already have an account?
        <a href="/login">Sign in</a>
      </p>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
