<%- include("partials/crm-shell-start", { title, currentUser, flashes, crmActiveNav: "people", crmTitle: "People", crmSearchAction: "/dashboard" }) %>

<section class="dashboard-page">
  <div class="dashboard-shell dashboard-stack">
    <div class="dashboard-header">
      <div>
        <p class="dashboard-eyebrow">Team</p>
        <h1 class="dashboard-title">People</h1>
        <p class="dashboard-subtitle">People connected to the workspace and spending categories you manage most often.</p>
      </div>
      <a href="/groups" class="btn-ghost">Open groups</a>
    </div>

    <section class="stats-grid">
      <article class="stat-panel">
        <span class="stat-label">People listed</span>
        <strong class="stat-value"><%= people.length %></strong>
        <span class="stat-meta">Workspace owner plus category leads</span>
      </article>
      <article class="stat-panel">
        <span class="stat-label">Top owner</span>
        <strong class="stat-value stat-value--small"><%= people[0] ? people[0].name : "N/A" %></strong>
        <span class="stat-meta">Primary workspace contact</span>
      </article>
      <article class="stat-panel">
        <span class="stat-label">Monthly spend</span>
        <strong class="stat-value stat-value--small">₹<%= monthlySpend.toFixed(2) %></strong>
        <span class="stat-meta">Tracked against budget collaboration</span>
      </article>
      <article class="stat-panel">
        <span class="stat-label">Health score</span>
        <strong class="stat-value stat-value--small"><%= healthScore %>/100</strong>
        <span class="stat-meta">Shared workspace health</span>
      </article>
    </section>

    <section class="dashboard-card">
      <div class="card-head">
        <h2>People directory</h2>
        <span class="card-note">Role-based overview</span>
      </div>

      <div class="category-stack">
        <% people.forEach((person) => { %>
          <div class="category-row">
            <div class="category-row-top">
              <span><%= person.name %></span>
              <span><%= person.role %></span>
            </div>
            <div class="category-row-bottom">
              <%= person.email %> · <%= person.phone %> · Managed value ₹<%= Number(person.spend).toFixed(2) %>
            </div>
          </div>
        <% }) %>
      </div>
    </section>
  </div>
</section>

<%- include("partials/crm-shell-end") %>
