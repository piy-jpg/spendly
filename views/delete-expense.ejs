<%- include("partials/header", { title, currentUser, flashes, extraCss: null }) %>

<section class="editor-page">
  <div class="editor-shell editor-shell--narrow">
    <div class="editor-card confirm-card">
      <p class="dashboard-eyebrow">Delete entry</p>
      <h1 class="dashboard-title">Remove this expense?</h1>
      <p class="dashboard-subtitle">This action cannot be undone.</p>

      <div class="confirm-summary">
        <div><strong><%= expense.title %></strong></div>
        <div><%= expense.category %> · ₹<%= Number(expense.amount).toFixed(2) %></div>
        <div><%= expense.expense_date %></div>
      </div>

      <form method="POST" action="/expenses/<%= expense.id %>/delete">
        <div class="editor-actions">
          <a href="/dashboard" class="btn-ghost">Cancel</a>
          <button type="submit" class="btn-danger">Delete expense</button>
        </div>
      </form>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
