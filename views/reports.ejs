<%- include("partials/crm-shell-start", { title, currentUser, flashes, crmActiveNav: "reports", crmTitle: "Reports / Export", crmSearchAction: "/dashboard" }) %>

<section class="dashboard-page">
  <div class="dashboard-shell dashboard-stack">
    <div class="dashboard-header">
      <div>
        <p class="dashboard-eyebrow">Tools</p>
        <h1 class="dashboard-title">Reports / Export</h1>
        <p class="dashboard-subtitle">Summarize key totals and export your workspace data for sharing or external reporting.</p>
      </div>
      <a href="/expenses/export" class="btn-primary">Export CSV</a>
    </div>

    <section class="stats-grid">
      <% reportCards.forEach((card) => { %>
        <article class="stat-panel">
          <span class="stat-label"><%= card.label %></span>
          <strong class="stat-value stat-value--small"><%= typeof card.value === "number" ? (card.label === "Transactions" ? card.value : `₹${card.value.toFixed(2)}`) : card.value %></strong>
          <span class="stat-meta"><%= card.note %></span>
        </article>
      <% }) %>
    </section>

    <section class="dashboard-card">
      <div class="card-head">
        <h2>Export workflow</h2>
        <span class="card-note">Share-ready output</span>
      </div>
      <div class="mini-metrics">
        <div class="mini-metric"><span>Use CSV export for finance review, archiving, or team sharing.</span></div>
        <div class="mini-metric"><span>Combine this page with Calendar, Forecast, and Recommendations for richer reporting.</span></div>
      </div>
    </section>
  </div>
</section>

<%- include("partials/crm-shell-end") %>
