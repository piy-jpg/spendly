<%
  const selectedExpense = expenses[0] || null;
  const topCategory = categoryRows[0] || null;
  const navSections = [
    {
      title: "MAIN",
      items: [{ label: "Dashboard", href: "/dashboard", icon: "house", active: true }],
    },
    {
      title: "FINANCE",
      items: [
        { label: "Expenses", href: "/expenses", icon: "receipt" },
        { label: "Transactions", href: "/transactions", icon: "money-bill-transfer" },
        { label: "Budgets", href: "/budgets", icon: "wallet" },
        { label: "Analytics", href: "/analytics", icon: "chart-line" },
        { label: "Goals", href: "/goals", icon: "bullseye" },
      ],
    },
    {
      title: "TEAM",
      items: [
        { label: "People", href: "/people", icon: "users" },
        { label: "Groups", href: "/groups", icon: "layer-group" },
        { label: "Chat", href: "/chat", icon: "comments" },
      ],
    },
    {
      title: "SMART",
      items: [
        { label: "Insights (AI)", href: "/insights", icon: "sparkles" },
        { label: "Recommendations", href: "/recommendations", icon: "lightbulb" },
        { label: "Forecast", href: "/forecast", icon: "arrow-trend-up" },
      ],
    },
    {
      title: "TOOLS",
      items: [
        { label: "Calendar", href: "/calendar", icon: "calendar-days" },
        { label: "Reports / Export", href: "/reports", icon: "share-nodes" },
      ],
    },
    {
      title: "SYSTEM",
      items: [
        { label: "Notifications", href: "/notifications", icon: "bell" },
        { label: "Profile", href: "/profile", icon: "user" },
        { label: "Settings", href: "/settings", icon: "gear" },
        { label: "Theme Toggle", href: "/theme", icon: "moon" },
        { label: "Help", href: "/help", icon: "circle-question" },
        { label: "Logout", href: "/logout", icon: "right-from-bracket" },
      ],
    },
  ];
%>
<%- include("partials/header", { title, currentUser, flashes, extraCss: null, bodyClass: "dashboard-crm-page" }) %>

<section class="crm-shell">
  <aside class="crm-sidebar">
    <div class="crm-sidebar-head">
      <div class="crm-user-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></div>
      <div class="crm-user-copy">
        <strong><%= currentUser.name %></strong>
        <span>Spendly workspace</span>
      </div>
      <a href="/settings" class="crm-close-link" aria-label="Open settings">×</a>
    </div>

    <div class="crm-sidebar-tools">
      <button type="button" class="crm-sidebar-add" data-modal-open="add-expense-modal">+ Add Expense</button>
      <form method="GET" action="/dashboard" class="crm-sidebar-search">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" name="q" value="<%= filters.q %>" placeholder="Search">
      </form>
    </div>

    <nav class="crm-nav">
      <% navSections.forEach((section) => { %>
        <div class="crm-nav-section">
          <div class="crm-nav-heading"><%= section.title %></div>
          <% section.items.forEach((item) => { %>
            <a href="<%= item.href %>" class="crm-nav-link <%= item.active ? 'is-active' : '' %>">
              <i class="fa-solid fa-<%= item.icon %>"></i>
              <span><%= item.label %></span>
            </a>
          <% }) %>
        </div>
      <% }) %>
    </nav>

    <div class="crm-sidebar-foot">
      <div class="crm-brand-lockup">
        <span class="crm-brand-icon">◈</span>
        <strong>SPENDLY</strong>
      </div>
      <a href="/logout" class="crm-foot-link">Logout</a>
    </div>
  </aside>

  <div class="crm-main">
    <header class="crm-topbar">
      <div class="crm-topbar-title">Sales</div>

      <form method="GET" action="/dashboard" class="crm-search">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" name="q" value="<%= filters.q %>" placeholder="Search">
      </form>

      <div class="crm-topbar-actions">
        <div class="crm-trial-pill">Health score <strong><%= healthScore %>/100</strong></div>
        <button type="button" class="crm-purchase-btn" data-modal-open="add-expense-modal">ADD EXPENSE</button>
        <a href="/expenses/export" class="crm-icon-btn" aria-label="Export data"><i class="fa-solid fa-plus"></i></a>
        <button type="button" class="crm-icon-btn" aria-label="Alerts"><i class="fa-solid fa-bell"></i></button>
      </div>
    </header>

    <div class="crm-content">
      <section class="crm-column crm-column--details">
        <article class="crm-card crm-card--header">
          <div class="crm-record-chip">
            <div class="crm-record-icon"><i class="fa-solid fa-wallet"></i></div>
            <div class="crm-record-copy">
              <h1><%= selectedExpense ? selectedExpense.title : "No recent expenses" %></h1>
              <p><%= selectedExpense ? `${selectedExpense.category} / ₹${Number(selectedExpense.amount).toFixed(2)}` : "Start by adding your first transaction." %></p>
            </div>
          </div>
          <div class="crm-record-actions">
            <button type="button" class="crm-star-btn" aria-label="Favorite"><i class="fa-solid fa-star"></i></button>
            <a href="/expenses" class="crm-more-btn" aria-label="Open expenses"><i class="fa-solid fa-ellipsis-vertical"></i></a>
          </div>
        </article>

        <article class="crm-card crm-card--form">
          <div class="crm-field-list">
            <div class="crm-field">
              <span class="crm-field-label">Name</span>
              <strong><%= selectedExpense ? selectedExpense.title : "No expense selected" %></strong>
            </div>
            <div class="crm-field">
              <span class="crm-field-label">Pipeline</span>
              <strong>Sales</strong>
            </div>
            <div class="crm-field">
              <span class="crm-field-label">Primary category</span>
              <strong><%= selectedExpense ? selectedExpense.category : "Choose a category" %></strong>
            </div>
            <div class="crm-field">
              <span class="crm-field-label">Close date</span>
              <strong><%= selectedExpense ? selectedExpense.expense_date : todayKey %></strong>
            </div>
            <div class="crm-field">
              <span class="crm-field-label">Company</span>
              <strong><%= topCategory ? `${topCategory.category} budget` : "Expense book" %></strong>
            </div>
            <div class="crm-field">
              <span class="crm-field-label">Status</span>
              <strong><%= budgetAlert ? budgetAlert.label : "Open" %></strong>
            </div>
            <div class="crm-field">
              <span class="crm-field-label">Owner</span>
              <strong><%= currentUser.name %></strong>
            </div>
            <div class="crm-field">
              <span class="crm-field-label">Stage</span>
              <strong><%= velocity.projectedTotal > monthlyBudget && monthlyBudget ? "Follow-up" : "On track" %></strong>
            </div>
            <div class="crm-field">
              <span class="crm-field-label">Source</span>
              <strong><%= hasActiveFilters ? "Filtered view" : "Main dashboard" %></strong>
            </div>
          </div>
        </article>
      </section>

      <section class="crm-column crm-column--activity">
        <div class="crm-sync-row">
          <span>Synced 4 minutes ago</span>
          <i class="fa-solid fa-rotate-right"></i>
        </div>

        <section class="crm-metric-strip">
          <article class="crm-metric-box">
            <strong><%= summary.total_count || 0 %></strong>
            <span>Interactions</span>
          </article>
          <article class="crm-metric-box">
            <strong><%= selectedExpense ? selectedExpense.expense_date : "--" %></strong>
            <span>Last Contacted</span>
          </article>
          <article class="crm-metric-box">
            <strong><%= todayStats.hasLoggedToday ? 0 : 1 %></strong>
            <span>Inactive Days</span>
          </article>
          <article class="crm-metric-box">
            <strong><%= healthScore %></strong>
            <span>Days in Stage</span>
          </article>
        </section>

        <article class="crm-card crm-composer">
          <div class="crm-tabs">
            <button type="button" class="is-active">LOG ACTIVITY</button>
            <button type="button">CREATE NOTE</button>
          </div>
          <div class="crm-composer-body">
            <div class="crm-composer-row">
              <span>To Do</span>
              <i class="fa-solid fa-caret-down"></i>
            </div>
            <form method="GET" action="/dashboard">
              <input type="text" name="q" value="<%= filters.q %>" placeholder="Click here to add a note">
            </form>
          </div>
        </article>

        <article class="crm-card crm-timeline-card">
          <div class="crm-section-head">
            <span>Today</span>
            <span>Showing: <strong>All Activity</strong></span>
          </div>

          <% if (expenses.length) { %>
            <div class="crm-timeline">
              <% expenses.slice(0, 6).forEach((expense) => { %>
                <div class="crm-timeline-item">
                  <div class="crm-timeline-icon"><i class="fa-solid fa-wallet"></i></div>
                  <div class="crm-timeline-copy">
                    <p>You added <strong><%= expense.title %></strong> in <a href="/expenses"><%= expense.category %></a></p>
                    <small><%= expense.notes || `Logged for ₹${Number(expense.amount).toFixed(2)}` %></small>
                  </div>
                  <time><%= expense.expense_date %></time>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="empty-state empty-state--compact">
              <h3>No activity yet</h3>
              <p>Add an expense and the dashboard timeline will start filling in.</p>
            </div>
          <% } %>
        </article>
      </section>

      <aside class="crm-column crm-column--rail">
        <article class="crm-side-panel">
          <div class="crm-side-head">
            <span>People (<%= Math.min(expenses.length, 2) %>)</span>
            <a href="/profile">+</a>
          </div>

          <% if (expenses.length) { %>
            <% expenses.slice(0, 2).forEach((expense) => { %>
              <div class="crm-person-row">
                <div class="crm-person-avatar"><%= expense.category.charAt(0) %></div>
                <div>
                  <strong><%= expense.title %></strong>
                  <p><%= expense.category %> at <a href="/expenses">Spendly Workspace</a></p>
                  <span>₹<%= Number(expense.amount).toFixed(2) %> | <%= expense.expense_date %></span>
                </div>
              </div>
            <% }) %>
            <a href="/expenses" class="crm-list-link">VIEW IN LIST</a>
          <% } else { %>
            <p class="empty-copy">No people-style records yet.</p>
          <% } %>
        </article>

        <article class="crm-side-stack">
          <div class="crm-stack-row">
            <span>Companies (<%= categoryRows.length %>)</span>
            <a href="/groups">+</a>
          </div>
          <div class="crm-stack-body">
            <% if (categoryRows.length) { %>
              <% categoryRows.slice(0, 4).forEach((row) => { %>
                <div class="crm-mini-row">
                  <span><%= row.category %></span>
                  <strong>₹<%= row.total.toFixed(0) %></strong>
                </div>
              <% }) %>
            <% } else { %>
              <span>No categories yet</span>
            <% } %>
          </div>
        </article>

        <article class="crm-side-stack">
          <div class="crm-stack-row">
            <span>Tasks (<%= advisorMessages.length %>)</span>
            <a href="/insights">+</a>
          </div>
          <div class="crm-stack-body">
            <% if (advisorMessages.length) { %>
              <% advisorMessages.slice(0, 3).forEach((message) => { %>
                <div class="crm-mini-copy"><%= message %></div>
              <% }) %>
            <% } else { %>
              <span>No active tasks</span>
            <% } %>
          </div>
        </article>

        <article class="crm-side-stack">
          <div class="crm-stack-row">
            <span>Files (<%= riskAlerts.length %>)</span>
            <a href="/notifications">+</a>
          </div>
          <div class="crm-stack-body">
            <% if (riskAlerts.length) { %>
              <% riskAlerts.slice(0, 3).forEach((alert) => { %>
                <div class="crm-mini-copy"><%= alert %></div>
              <% }) %>
            <% } else { %>
              <span>No risk alerts</span>
            <% } %>
          </div>
        </article>

        <article class="crm-side-stack">
          <div class="crm-stack-row">
            <span>Calendar Events (<%= weeklySummary.rows.length %>)</span>
            <a href="/analytics">+</a>
          </div>
          <div class="crm-stack-body">
            <% weeklySummary.rows.slice(-3).forEach((row) => { %>
              <div class="crm-mini-row">
                <span><%= row.label %></span>
                <strong>₹<%= row.total.toFixed(0) %></strong>
              </div>
            <% }) %>
          </div>
        </article>

        <article class="crm-side-stack">
          <div class="crm-stack-row">
            <span>Projects (1)</span>
            <a href="/budgets">+</a>
          </div>
          <div class="crm-stack-body">
            <div class="crm-mini-copy">Budget left: <strong><%= monthlyBudget ? `₹${remainingBudget.toFixed(0)}` : "Set budget" %></strong></div>
            <div class="crm-mini-copy">Projection: <strong>₹<%= velocity.projectedTotal.toFixed(0) %></strong></div>
          </div>
        </article>
      </aside>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
