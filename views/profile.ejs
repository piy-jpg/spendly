<%- include("partials/crm-shell-start", { title, currentUser, flashes, crmActiveNav: "profile", crmTitle: "Profile", crmSearchAction: "/dashboard" }) %>

<section class="dashboard-page">
  <div class="dashboard-shell dashboard-stack">
    <div class="dashboard-header">
      <div>
        <p class="dashboard-eyebrow">System</p>
        <h1 class="dashboard-title">Profile</h1>
        <p class="dashboard-subtitle">Your account hub for identity, activity history, budget context, and shortcuts into system pages.</p>
      </div>
      <div class="header-actions">
        <a href="/notifications" class="btn-ghost">Notifications</a>
        <a href="/settings" class="btn-primary">Settings</a>
      </div>
    </div>

    <div class="stats-grid">
      <article class="stat-panel">
        <span class="stat-label">Account email</span>
        <strong class="stat-value stat-value--small"><%= currentUser.email %></strong>
        <span class="stat-meta">Used for sign in and account recovery</span>
      </article>
      <article class="stat-panel">
        <span class="stat-label">Total transactions</span>
        <strong class="stat-value"><%= summary.total_count %></strong>
        <span class="stat-meta">Expenses recorded so far</span>
      </article>
      <article class="stat-panel">
        <span class="stat-label">Monthly budget</span>
        <strong class="stat-value stat-value--small"><%= monthlyBudget ? `₹${monthlyBudget.toFixed(2)}` : "Not set" %></strong>
        <span class="stat-meta">Budget for the current month</span>
      </article>
      <article class="stat-panel">
        <span class="stat-label">This month spent</span>
        <strong class="stat-value stat-value--small">₹<%= monthlySpend.toFixed(2) %></strong>
        <span class="stat-meta">Compared against your budget</span>
      </article>
      <article class="stat-panel">
        <span class="stat-label">Latest activity</span>
        <strong class="stat-value stat-value--small"><%= summary.latest_date || "No activity yet" %></strong>
        <span class="stat-meta">Last expense date</span>
      </article>
    </div>

    <div class="dashboard-grid">
      <article class="dashboard-card">
        <div class="card-head">
          <h2>Account snapshot</h2>
          <span class="card-note">Identity and access</span>
        </div>
        <div class="insight-list">
          <div class="insight-item insight-item--smart">
            <span class="insight-label">Account owner</span>
            <strong><%= currentUser.name %></strong>
            <p>This profile represents the primary account that owns the current workspace and its financial views.</p>
          </div>
          <div class="insight-item insight-item--smart">
            <span class="insight-label">Workspace access</span>
            <strong>Dashboard, Finance, Team, Smart, System</strong>
            <p>Your navbar now routes directly to each functional area so profile acts as the system anchor, not a dead-end page.</p>
          </div>
        </div>
      </article>

      <article class="dashboard-card">
        <div class="card-head">
          <h2>System shortcuts</h2>
          <span class="card-note">Profile role actions</span>
        </div>
        <div class="category-stack">
          <div class="category-row">
            <div class="category-row-top">
              <span>Open settings</span>
              <a href="/settings">Go</a>
            </div>
            <div class="category-row-bottom">Manage theme guidance, export shortcuts, and account-level preferences.</div>
          </div>
          <div class="category-row">
            <div class="category-row-top">
              <span>Open notifications</span>
              <a href="/notifications">Go</a>
            </div>
            <div class="category-row-bottom">Review budget alerts, system updates, and suggested actions in one place.</div>
          </div>
          <div class="category-row">
            <div class="category-row-top">
              <span>Return to dashboard</span>
              <a href="/dashboard">Go</a>
            </div>
            <div class="category-row-bottom">Jump back to the CRM-style dashboard and continue from the main workspace.</div>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<%- include("partials/crm-shell-end") %>
