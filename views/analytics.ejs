<%- include("partials/header", { title, currentUser, flashes, extraCss: `
<style>
  .analytics-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }
  
  .analytics-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .analytics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }
  
  .chart-card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  
  .chart-card h3 {
    margin: 0 0 1rem 0;
    color: #333;
    font-size: 1.25rem;
  }
  
  .chart-container {
    position: relative;
    height: 300px;
  }
  
  .insights-card {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
  }
  
  .insights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  
  .insight-item {
    text-align: center;
  }
  
  .insight-value {
    font-size: 2rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }
  
  .insight-label {
    opacity: 0.9;
    font-size: 0.9rem;
  }
  
  @media (max-width: 768px) {
    .analytics-grid {
      grid-template-columns: 1fr;
    }
    
    .analytics-container {
      padding: 1rem;
    }
  }
</style>
` }) %>

<div class="analytics-container">
  <div class="analytics-header">
    <h1>Spending Analytics</h1>
    <p>Gain insights into your spending patterns and habits</p>
  </div>
  
  <% if (spendingTrends.length > 0) { %>
    <div class="insights-card">
      <h2>Quick Insights</h2>
      <div class="insights-grid">
        <div class="insight-item">
          <div class="insight-value">₹<%= spendingTrends.reduce((sum, trend) => sum + trend.total_spent, 0).toFixed(0) %></div>
          <div class="insight-label">Last <%= spendingTrends.length %> months</div>
        </div>
        <div class="insight-item">
          <div class="insight-value">₹<%= (spendingTrends.reduce((sum, trend) => sum + trend.total_spent, 0) / spendingTrends.length).toFixed(0) %></div>
          <div class="insight-label">Monthly Average</div>
        </div>
        <div class="insight-item">
          <div class="insight-value"><%= categoryBreakdown[0]?.category || 'N/A' %></div>
          <div class="insight-label">Top Category</div>
        </div>
        <div class="insight-item">
          <div class="insight-value"><%= dailyPattern.sort((a, b) => b.total_spent - a.total_spent)[0]?.day_name || 'N/A' %></div>
          <div class="insight-label">Peak Spending Day</div>
        </div>
      </div>
    </div>
  <% } %>
  
  <div class="analytics-grid">
    <div class="chart-card">
      <h3>Spending Trends (6 Months)</h3>
      <div class="chart-container">
        <canvas id="spendingTrendsChart"></canvas>
      </div>
    </div>
    
    <div class="chart-card">
      <h3>Category Breakdown (3 Months)</h3>
      <div class="chart-container">
        <canvas id="categoryChart"></canvas>
      </div>
    </div>
    
    <div class="chart-card">
      <h3>Daily Spending Pattern</h3>
      <div class="chart-container">
        <canvas id="dailyPatternChart"></canvas>
      </div>
    </div>
    
    <div class="chart-card">
      <h3>Monthly Category Comparison</h3>
      <div class="chart-container">
        <canvas id="monthlyComparisonChart"></canvas>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // Data from server
  const spendingTrendsData = <%- JSON.stringify(spendingTrends) %>;
  const categoryBreakdownData = <%- JSON.stringify(categoryBreakdown) %>;
  const dailyPatternData = <%- JSON.stringify(dailyPattern) %>;
  const monthlyComparisonData = <%- JSON.stringify(monthlyComparison) %>;
  
  // Chart defaults
  Chart.defaults.font.family = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif';
  
  // Spending Trends Chart
  const spendingTrendsCtx = document.getElementById('spendingTrendsChart').getContext('2d');
  new Chart(spendingTrendsCtx, {
    type: 'line',
    data: {
      labels: spendingTrendsData.map(t => t.month),
      datasets: [{
        label: 'Monthly Spending',
        data: spendingTrendsData.map(t => t.total_spent),
        borderColor: 'rgb(75, 192, 192)',
        backgroundColor: 'rgba(75, 192, 192, 0.2)',
        tension: 0.1
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            callback: function(value) {
              return '₹' + value.toLocaleString();
            }
          }
        }
      }
    }
  });
  
  // Category Breakdown Chart
  const categoryCtx = document.getElementById('categoryChart').getContext('2d');
  new Chart(categoryCtx, {
    type: 'doughnut',
    data: {
      labels: categoryBreakdownData.map(c => c.category),
      datasets: [{
        data: categoryBreakdownData.map(c => c.total_spent),
        backgroundColor: [
          '#FF6384',
          '#36A2EB',
          '#FFCE56',
          '#4BC0C0',
          '#9966FF',
          '#FF9F40',
          '#FF6384',
          '#C9CBCF'
        ]
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          position: 'bottom'
        },
        tooltip: {
          callbacks: {
            label: function(context) {
              const label = context.label || '';
              const value = '₹' + context.parsed.toLocaleString();
              const percentage = categoryBreakdownData[context.dataIndex]?.percentage || 0;
              return `${label}: ${value} (${percentage}%)`;
            }
          }
        }
      }
    }
  });
  
  // Daily Pattern Chart
  const dailyPatternCtx = document.getElementById('dailyPatternChart').getContext('2d');
  new Chart(dailyPatternCtx, {
    type: 'bar',
    data: {
      labels: dailyPatternData.map(d => d.day_name),
      datasets: [{
        label: 'Total Spent',
        data: dailyPatternData.map(d => d.total_spent),
        backgroundColor: 'rgba(54, 162, 235, 0.8)',
        borderColor: 'rgba(54, 162, 235, 1)',
        borderWidth: 1
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            callback: function(value) {
              return '₹' + value.toLocaleString();
            }
          }
        }
      }
    }
  });
  
  // Monthly Comparison Chart
  const monthlyComparisonCtx = document.getElementById('monthlyComparisonChart').getContext('2d');
  
  // Process data for stacked bar chart
  const monthlyData = {};
  
  monthlyComparisonData.forEach(item => {
    if (!monthlyData[item.month]) {
      monthlyData[item.month] = {};
    }
    monthlyData[item.month][item.category] = item.amount;
  });
  
  const months = Object.keys(monthlyData).sort().reverse().slice(0, 6);
  const categories = [...new Set(monthlyComparisonData.map(item => item.category))];
  
  const datasets = categories.map((category, index) => ({
    label: category,
    data: months.map(month => monthlyData[month]?.[category] || 0),
    backgroundColor: [
      '#FF6384',
      '#36A2EB',
      '#FFCE56',
      '#4BC0C0',
      '#9966FF',
      '#FF9F40',
      '#FF6384',
      '#C9CBCF'
    ][index % 8]
  }));
  
  new Chart(monthlyComparisonCtx, {
    type: 'bar',
    data: {
      labels: months,
      datasets: datasets
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          position: 'bottom'
        }
      },
      scales: {
        x: {
          stacked: true
        },
        y: {
          stacked: true,
          beginAtZero: true,
          ticks: {
            callback: function(value) {
              return '₹' + value.toLocaleString();
            }
          }
        }
      }
    }
  });
</script>

<%- include("partials/footer") %>
